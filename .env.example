# Copy to `.env` and adjust. Loaded automatically by wiki_langgraph.config.Settings.
# See README for descriptions.

# WIKI_DATA_RAW_DIR=
# WIKI_DATA_WIKI_DIR=   # e.g. vault/.../wiki — leading segments of raw URIs that match this path suffix are not duplicated on disk (avoids .../wiki/wiki/...)
# WIKI_OPENAI_API_BASE=http://127.0.0.1:8080/v1
# WIKI_OPENAI_API_KEY=not-needed
# WIKI_LLM_MODEL=local
# Seconds per HTTP request (default 300; long local generations may need more)
# WIKI_LLM_REQUEST_TIMEOUT_SEC=300
# LLM "compile" — rewrite each raw .md via chat before writing wiki (Obsidian OFM); needs API base
# WIKI_LLM_COMPILE=false
# Parallel author requests (default 1 — local servers usually one completion at a time; >1 can cause timeouts)
# WIKI_LLM_COMPILE_MAX_WORKERS=1
# Only re-author .md files whose raw content changed (manifest under data/.wiki-langgraph/)
# WIKI_LLM_COMPILE_INCREMENTAL=true
# Enrich existing wiki notes (Pal-style "merge, don't replace") instead of full rewrite when wiki note exists
# WIKI_LLM_COMPILE_ENRICH=false
# WIKI_MANIFEST_PATH=   # optional override for hash manifest JSON
# Set true with WIKI_OPENAI_API_BASE to suggest related notes per file (local LLM / Ollama)
# WIKI_SEMANTIC_LINKS=false
# Semantic related notes: llm (needs API base) or qmd (local CLI, fast search + scores)
# WIKI_SEMANTIC_BACKEND=llm
# WIKI_QMD_COLLECTION=cursor
# WIKI_QMD_MIN_SCORE=0.35
# WIKI_QMD_TOP_N=10
# After compile, optionally run `qmd update` + `qmd embed` so the vault index is fresh.
# Default is false so a minimal run does not require qmd; enable when you want local QMD indexing.
# WIKI_QMD_REFRESH=false
# If qmd/node-llama-cpp errors on Metal (ggml_metal_library_init_from_source), set true for CPU-only (slower)
# WIKI_QMD_CPU_ONLY=false
# After index, run vault lint; any issue fails the run (exit 1). Set false to skip.
# WIKI_LINT_ON_RUN=true
# Optional: append run traces (DEBUG shows per-file semantic edge counts)
# WIKI_LOG_FILE=logs/wiki-langgraph.log
# WIKI_LOG_LEVEL=INFO
# Optional: override Obsidian OFM skill file for plain LLM prompts (Deep Agents uses skills/ on disk)
# WIKI_OBSIDIAN_MARKDOWN_SKILL_PATH=/path/to/SKILL.md
